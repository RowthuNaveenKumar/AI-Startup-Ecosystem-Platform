#################################################
# Global Project Ignore
#################################################

###############################
# OS Files
###############################
.DS_Store
Thumbs.db

###############################
# Logs
###############################
*.log
logs/

###############################
# Environment / Secrets
###############################
.env
.env.*
*.pem
*.key
*.p12
*.jks

###############################
# IDE Files
###############################
.idea/
.vscode/
*.iml
*.ipr
*.iws

###############################
# Temporary Files
###############################
*.tmp
*.swp
*.swo

#################################################
# FRONTEND (React)
#################################################

frontend/node_modules/
frontend/build/
frontend/dist/
frontend/.env
frontend/.env.*

#################################################
# DATABASE FILES (optional local db dumps)
#################################################

database/*.sql
database/*.dump
database/*.bak